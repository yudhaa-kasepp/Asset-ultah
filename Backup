*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Poppins',sans-serif;scroll-behavior:smooth;overflow-x:hidden}

/* Background Image - */
.bg-img{position:fixed;top:0;left:0;width:100%;height:100%;object-fit:cover;z-index:-1}

