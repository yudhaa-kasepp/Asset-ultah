@keyframes fade{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}

.title{font-family:'Playfair Display',serif;font-size:32px;color:#b76e79;margin-bottom:5px}
.subtitle{font-size:14px;letter-spacing:2px;color:#9a6b73;margin-bottom:25px;text-transform:uppercase}

