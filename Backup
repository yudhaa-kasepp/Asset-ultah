<script>
const music=document.getElementById('music');
const musicBtn=document.getElementById('musicBtn');
let play=false;

function openInvitation(){
music.play().then(()=>{play=true;musicBtn.innerHTML="🔊";}).catch(e=>{});
document.getElementById('s2').scrollIntoView({behavior:'smooth'});
}

function toggleMusic(){
if(!play){
music.play().then(()=>{play=true;musicBtn.innerHTML="🔊";}).catch(e=>{});
}else{
if(music.paused){music.play();musicBtn.innerHTML="🔊";}
else{music.pause();musicBtn.innerHTML="🔇";}
}
}

setInterval(() => {
  document.querySelectorAll('.heart').forEach(heart => {
    heart.style.animation = 'none';
    heart.offsetHeight;
    heart.style.animation = null;
  });
}, 10000);
