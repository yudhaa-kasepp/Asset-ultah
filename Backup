.photo-frame img{width:100%;height:100%;border-radius:50%;object-fit:cover}

.message{font-size:15px;line-height:1.7;color:#6d3c45;margin-bottom:20px}

.btn{margin-top:10px;padding:12px 30px;border:none;border-radius:30px;background:#c97c88;color:white;cursor:pointer;font-size:14px;font-family:'Poppins',sans-serif;font-weight:600;text-transform:uppercase;letter-spacing:1px;display:inline-block;text-decoration:none;transition:all .3s ease}
.btn:hover{background:#b56b76;transform:scale(1.05)}

.music-btn{position:fixed;top:20px;right:20px;width:50px;height:50px;border-radius:50%;border:none;background:white;box-shadow:0 6px 20px rgba(0,0,0,.15);font-size:22px;cursor:pointer;z-index:100;display:flex;align-items:center;justify-content:center;transition:transform .2s}
.music-btn:active{transform:scale(.9)}

@media (max-width:480px){
.photo-frame{width:160px;height:160px}
.title{font-size:28px}
.card{padding:25px 20px}
}

/* --- HUJAN HATI --- */
.heart{position:fixed;top:-10%;z-index:99;color:#e91e63;font-size:24px;animation:fall linear forwards;opacity:0.8}
@keyframes fall{0%{top:-10%;transform:translateX(0) rotate(0deg)}100%{top:110%;transform:translateX(100px) rotate(360deg)}}

.heart:nth-child(1){left:10%;animation-duration:8s;animation-delay:0s;font-size:20px}
.heart:nth-child(2){left:20%;animation-duration:7s;animation-delay:1s;font-size:28px}
.heart:nth-child(3){left:30%;animation-duration:9s;animation-delay:2s;font-size:18px}
.heart:nth-child(4){left:40%;animation-duration:6s;animation-delay:0.5s;font-size:24px}
.heart:nth-child(5){left:50%;animation-duration:8s;animation-delay:1.5s;font-size:30px}
.heart:nth-child(6){left:60%;animation-duration:7s;animation-delay:2.5s;font-size:22px}
.heart:nth-child(7){left:70%;animation-duration:9s;animation-delay:0.8s;font-size:26px}
.heart:nth-child(8){left:80%;animation-duration:6s;animation-delay:1.2s;font-size:20px}
.heart:nth-child(9){left:90%;animation-duration:8s;animation-delay:2s;font-size:28px}

/* --- TEKS KAKI (右下) --- */
